            </View>
            <View
              style={
                {
                  "flex": 1,
                }
              }
            >
              <Pressable
                accessibilityRole="button"
                disabled={false}
                onPress={[Function]}
                style={[Function]}
              >
                <View
                  style={
                    [
                      {
                        "alignItems": "center",
                        "flexDirection": "row",
                        "gap": 8,
                      },
                      {
                        "justifyContent": "center",
                      },
                    ]
                  }
                >
                  <Text
                    style={
                      [
                        {
                          "color": "#F5F8FF",
                          "fontSize": 15,
                          "lineHeight": 21,
                        },
                        {
                          "color": "#08111F",
                          "fontSize": 16,
                          "fontWeight": "800",
                        },
                      ]
                    }
                  >
                    Apply
                  </Text>
                </View>
              </Pressable>
            </View>
          </View>
        </View>
      </View>
    </View>
  </Modal>,
]
`;
